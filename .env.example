# Career-Ops — Environment Variables
# Copy this file to .env and fill in your values.
# .env is gitignored and will never be committed.

# ── Claude / Anthropic ──────────────────────────────────────────────────────
# Required by Claude Code CLI (set via `claude config set apiKey` or here)
ANTHROPIC_API_KEY=

# ── Google Gemini (optional) ─────────────────────────────────────────────────
# Used if you build AI MVPs with the Gemini API (e.g. AI Readiness Assessment)
GEMINI_API_KEY=

# ── Canva MCP (optional) ─────────────────────────────────────────────────────
# Required only if you use Canva MCP for visual CV generation
# See: https://www.canva.com/developers/integrations/
CANVA_API_KEY=

# ── Supabase (optional) ──────────────────────────────────────────────────────
# Required only if you use Supabase in your own AI MVPs
SUPABASE_URL=
SUPABASE_ANON_KEY=

# ── Playwright / PDF generation ──────────────────────────────────────────────
# No API key needed — Playwright uses a local Chromium browser.
# Run once after npm install: npx playwright install chromium
